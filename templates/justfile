# Template: justfile
#
# Shell: PowerShell Core (pwsh). Requires pwsh to be on PATH.
#
# Shared-venv convention:
#   Set UIPS_BROWSER_KIT_ROOT to the workspace root (e.g. D:\work\uips-browser-kit).
#   onboarding/shared.ps1 derives UV_PROJECT_ENVIRONMENT from it automatically.
#   All just recipes rely on UV_PROJECT_ENVIRONMENT being present; no path is
#   hardcoded. Run `just install` once after cloning.

set shell := ["pwsh", "-NoProfile", "-Command"]

default: help

help:
    @just --list

# Add this package to the shared venv in editable mode
install:
    uv pip install -e .

# Add a runtime dependency and record it in pyproject.toml
add dep:
    uv add {{ dep }}

# Add a dev dependency
add-dev dep:
    uv add --dev {{ dep }}

# Run linter
lint:
    uv run ruff check .

# Run formatter
fmt:
    uv run ruff format .

# Run linter and formatter together
check: lint fmt

# Run tests
test:
    uv run pytest
