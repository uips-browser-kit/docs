# Template: justfile
#
# Shared-venv convention:
#   UV_PROJECT_ENVIRONMENT must point to the shared .venv in the common parent
#   folder. Set it via direnv (.envrc at the workspace root) or export it
#   manually before running just.
#
#   The install recipe adds this package to the shared venv in editable mode.
#   It does not create a new venv. Run it once after cloning.

default: help

help:
    @just --list

# Add this package to the shared venv in editable mode
install:
    uv pip install -e .

# Add a runtime dependency and record it in pyproject.toml
add dep:
    uv add {{ dep }}

# Add a dev dependency
add-dev dep:
    uv add --dev {{ dep }}

# Run linter
lint:
    uv run ruff check .

# Run formatter
fmt:
    uv run ruff format .

# Run linter and formatter together
check: lint fmt

# Run tests
test:
    uv run pytest
